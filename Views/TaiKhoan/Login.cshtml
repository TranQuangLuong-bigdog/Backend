@{
    Layout = null; // Ẩn thanh menu chung, chỉ hiện box đăng nhập
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Đăng nhập - Khoa CNTT</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
            body {
                background-color: #f4f6f9;
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .login-box {
                width: 400px;
                background: #fff;
                padding: 30px;
                border-radius: 8px;
                box-shadow: 0 4px 10px rgba(0,0,0,0.1);
                border-top: 5px solid #3c8dbc;
            }
    </style>
</head>
<body>

    <div class="login-box">
        <div class="text-center mb-4">
            <h4 class="fw-bold">HỆ THỐNG NỘI VỤ</h4>
            <p class="text-muted">Khoa Công Nghệ Thông Tin</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger text-center">@ViewBag.Error</div>
        }

        <form asp-action="Login" asp-controller="TaiKhoan" method="post">
            <div class="mb-3">
                <label class="form-label fw-bold">Email đăng nhập</label>
                <input type="email" name="email" class="form-control" required placeholder="NhomVip@gmail.com">
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Mật khẩu</label>
                <input type="password" name="matkhau" class="form-control" required placeholder="••••••">
            </div>
            <div class="d-grid mt-4">
                <button type="submit" class="btn btn-primary btn-lg">Đăng nhập hệ thống</button>
            </div>
            <div class="text-center mt-3">
                <a asp-controller="TaiKhoan" asp-action="Register">
                    Chưa có tài khoản? Đăng ký
                </a>
            </div>
        </form>
    </div>  

</body>
</html>