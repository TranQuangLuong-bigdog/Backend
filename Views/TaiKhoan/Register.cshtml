@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <title>Đăng ký</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
            body {
                background: #f4f6f9;
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .box {
                width: 400px;
                background: white;
                padding: 30px;
                border-radius: 10px;
                box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            }
    </style>
</head>

<body>

    <div class="box">
        <h4 class="text-center mb-3">Đăng ký tài khoản</h4>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <form asp-action="Register" method="post">

            <div class="mb-3">
                <label>Họ tên</label>
                <input name="hoten" class="form-control" required />
            </div>

            <div class="mb-3">
                <label>Email</label>
                <input name="email" type="email" class="form-control" required />
            </div>

            <div class="mb-3">
                <label>Mật khẩu</label>
                <input name="matkhau" type="password" class="form-control" required />
            </div>

            <button class="btn btn-success w-100">Đăng ký</button>

            <div class="text-center mt-3">
                <a href="/TaiKhoan/Login">Đã có tài khoản? Đăng nhập</a>
            </div>
        </form>
    </div>

</body>
</html>