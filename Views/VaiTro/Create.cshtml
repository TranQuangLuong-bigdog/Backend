@model KhoaNoiVuCNTT.Models.VaiTro

@{
    ViewData["Title"] = "Thêm mới Vai Trò";
}

<div class="container-fluid py-4 px-lg-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0" style="border-radius: 16px;">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <div class="d-flex align-items-center">
                        <a asp-action="Index" class="btn btn-sm btn-outline-secondary rounded-circle me-3" style="width: 32px; height: 32px; padding: 3px; display: flex; align-items: center; justify-content: center;">
                            <i class="fas fa-arrow-left"></i>
                        </a>
                        <h4 class="mb-0 fw-bold text-success"><i class="fas fa-plus-circle me-2"></i>Thêm Phân Quyền Mới</h4>
                    </div>
                </div>
                
                <div class="card-body p-4">
                    <form asp-action="Create" class="needs-validation" novalidate>
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>
                        
                        <div class="mb-4">
                            <label asp-for="TenVaiTro" class="form-label fw-bold small text-muted">Tên Vai Trò <span class="text-danger">*</span></label>
                            <input asp-for="TenVaiTro" class="form-control form-control-lg fs-6" style="border-radius: 10px;" placeholder="VD: Trưởng Khoa, Giảng viên..." required minlength="3" />
                            <span asp-validation-for="TenVaiTro" class="text-danger small mt-1 d-block"></span>
                            
                            @if (!ViewData.ModelState.IsValid && ViewData.ModelState["TenVaiTro"]?.Errors.Count > 0)
                            {
                                <div class="text-danger small mt-1">
                                    <i class="fas fa-exclamation-circle me-1"></i> @ViewData.ModelState["TenVaiTro"].Errors[0].ErrorMessage
                                </div>
                            }
                        </div>

                        <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-light px-4 me-2" style="border-radius: 8px;">Hủy bỏ</a>
                            <button type="submit" class="btn btn-success px-4 shadow-sm" style="border-radius: 8px;">
                                <i class="fas fa-save me-2"></i>Lưu thông tin
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    
    <script>
                // Bật tính năng báo lỗi đỏ của Bootstrap nếu để trống
                (function () {
        'use strict'
                    var forms = document.querySelectorAll('.needs-validation')
                    Array.prototype.slice.call(forms).forEach(function (form) {
                        form.addEventListener('submit', function (event) {
                            if (!form.checkValidity()) {
                                event.preventDefault()
                                event.stopPropagation()
                            }
                            form.classList.add('was-validated')
                        }, false)
                    })
                })()
    </script>
}