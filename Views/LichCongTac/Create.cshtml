@model KhoaNoiVuCNTT.Models.LichCongTac

@{
    ViewData["Title"] = "Thêm Lịch Công Tác";
}

<div class="container-fluid py-4 px-lg-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0" style="border-radius: 16px;">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <div class="d-flex align-items-center">
                        <a asp-action="Index" class="btn btn-sm btn-outline-secondary rounded-circle me-3" style="width: 32px; height: 32px; padding: 3px; display: flex; align-items: center; justify-content: center;">
                            <i class="fas fa-arrow-left"></i>
                        </a>
                        <h4 class="mb-0 fw-bold text-success"><i class="fas fa-calendar-plus me-2"></i>Lên Lịch Mới</h4>
                    </div>
                </div>
                
                <div class="card-body p-4">
                    <form asp-action="Create" class="needs-validation" novalidate>
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>
                        
                        <div class="row g-4">
                            <div class="col-md-12">
                                <label asp-for="TieuDe" class="form-label fw-bold small text-muted">Tiêu đề Sự kiện / Cuộc họp <span class="text-danger">*</span></label>
                                <input asp-for="TieuDe" class="form-control form-control-lg fs-6" style="border-radius: 10px;" placeholder="VD: Họp giao ban khoa..." required minlength="5" />
                                <span asp-validation-for="TieuDe" class="text-danger small mt-1"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ThoiGianBatDau" class="form-label fw-bold small text-muted">Thời gian Bắt đầu <span class="text-danger">*</span></label>
                                <input asp-for="ThoiGianBatDau" type="datetime-local" class="form-control" style="border-radius: 10px;" required />
                                <span asp-validation-for="ThoiGianBatDau" class="text-danger small mt-1"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ThoiGianKetThuc" class="form-label fw-bold small text-muted">Thời gian Kết thúc <span class="text-danger">*</span></label>
                                <input asp-for="ThoiGianKetThuc" type="datetime-local" class="form-control" style="border-radius: 10px;" required />
                                @if (!ViewData.ModelState.IsValid && ViewData.ModelState["ThoiGianKetThuc"]?.Errors.Count > 0)
                                {
                                    <div class="text-danger small mt-1">
                                        <i class="fas fa-exclamation-circle me-1"></i> @ViewData.ModelState["ThoiGianKetThuc"].Errors[0].ErrorMessage
                                    </div>
                                }
                            </div>

                            <div class="col-md-6">
                                <label asp-for="DiaDiem" class="form-label fw-bold small text-muted">Địa điểm tổ chức <span class="text-danger">*</span></label>
                                <input asp-for="DiaDiem" class="form-control" style="border-radius: 10px;" placeholder="VD: Phòng họp 201..." required />
                                <span asp-validation-for="DiaDiem" class="text-danger small mt-1"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="MaNguoiToChuc" class="form-label fw-bold small text-muted">Cán bộ phụ trách <span class="text-danger">*</span></label>
                                <select asp-for="MaNguoiToChuc" class="form-select" style="border-radius: 10px;" asp-items="ViewBag.MaNguoiToChuc" required></select>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="MoTa" class="form-label fw-bold small text-muted">Mô tả nội dung / Ghi chú</label>
                                <textarea asp-for="MoTa" class="form-control" style="border-radius: 10px;" rows="4" placeholder="Nhập nội dung chuẩn bị, thành phần tham dự..."></textarea>
                                <span asp-validation-for="MoTa" class="text-danger small mt-1"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end mt-4 pt-4 border-top">
                            <a asp-action="Index" class="btn btn-light px-4 me-2" style="border-radius: 8px;">Hủy bỏ</a>
                            <button type="submit" class="btn btn-success px-4 shadow-sm" style="border-radius: 8px;">
                                <i class="fas fa-save me-2"></i>Lưu Lịch Công Tác
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        (function () {
            'use strict'
            var forms = document.querySelectorAll('.needs-validation')
            Array.prototype.slice.call(forms).forEach(function (form) {
                form.addEventListener('submit', function (event) {
                    if (!form.checkValidity()) {
                        event.preventDefault()
                        event.stopPropagation()
                    }
                    form.classList.add('was-validated')
                }, false)
            })
        })()
    </script>
}