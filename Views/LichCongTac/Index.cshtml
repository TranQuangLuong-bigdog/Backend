@model IEnumerable<KhoaNoiVuCNTT.Models.LichCongTac>

@{
    ViewData["Title"] = "Lịch Công Tác";
    var totalLich = Model?.Count() ?? 0;
}

<style>
    :root {
        --primary-soft: #eef2ff;
        --primary-dark: #4338ca;
    }
    body { background-color: #f9fafb; font-family: 'Inter', sans-serif; }
    .stat-card { border: none; border-radius: 12px; transition: transform 0.2s; }
    .stat-card:hover { transform: translateY(-5px); }
    .table-container { background: white; border-radius: 16px; overflow: hidden; }
    .search-input { border-radius: 10px 0 0 10px; border-right: none; }
    .search-btn { border-radius: 0 10px 10px 0; }
</style>

<div class="container-fluid py-4 px-lg-5">
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card stat-card shadow-sm bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="mb-1 opacity-75 small">Tổng số Sự kiện / Cuộc họp</p>
                            <h3 class="mb-0 fw-bold">@totalLich <span class="fs-6 fw-normal">lịch trình</span></h3>
                        </div>
                        <div class="bg-white bg-opacity-25 rounded-circle p-3">
                            <i class="fas fa-calendar-alt fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4 px-3 py-2">
        <div class="row align-items-center g-3">
            <div class="col-lg-6">
                <div class="input-group">
                    <input type="text" id="mainSearch" class="form-control search-input" placeholder="Tìm tiêu đề, địa điểm, người tổ chức...">
                    <button class="btn btn-primary search-btn"><i class="fas fa-search"></i></button>
                </div>
            </div>
            <div class="col-lg-6 text-lg-end">
                <a asp-action="Create" class="btn btn-success px-4 shadow-sm">
                    <i class="fas fa-calendar-plus me-2"></i>Thêm Lịch Công Tác
                </a>
            </div>
        </div>
    </div>

    <div class="table-container shadow-sm border">
        <table class="table table-hover align-middle mb-0" id="masterTable">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4" style="width: 30%;">Sự kiện / Cuộc họp</th>
                    <th style="width: 25%;">Thời gian diễn ra</th>
                    <th style="width: 25%;">Địa điểm & Người tổ chức</th>
                    <th class="text-center" style="width: 20%;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
<tr>
                            <td class="ps-4">
                                <h6 class="mb-1 fw-bold text-dark">@item.TieuDe</h6>
                                <small class="text-muted d-block text-truncate" style="max-width: 250px;">@item.MoTa</small>
                            </td>
                            <td>
                                <div class="small">
                                    <div class="text-success fw-bold mb-1">
                                        <i class="fas fa-play-circle me-1"></i> Bắt đầu: @item.ThoiGianBatDau.ToString("dd/MM/yyyy - HH:mm")
                                    </div>
                                    <div class="text-danger">
                                        <i class="fas fa-stop-circle me-1"></i> Kết thúc: @item.ThoiGianKetThuc.ToString("dd/MM/yyyy - HH:mm")
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="small">
                                    <div class="text-dark fw-bold mb-1">
                                        <i class="fas fa-map-marker-alt text-danger me-1"></i> @item.DiaDiem
                                    </div>
                                    <div class="text-muted">
                                        <i class="fas fa-user-tie text-primary me-1"></i> Phụ trách: @item.MaNguoiToChucNavigation?.HoTen
                                    </div>
                                </div>
                            </td>
                            <td class="text-center">
                                <div class="btn-group shadow-sm">
                                    <a class="btn btn-sm btn-outline-warning" asp-action="Edit" asp-route-id="@item.MaLich">
                                        <i class="fas fa-edit me-1"></i> Sửa
                                    </a>
                                    <a class="btn btn-sm btn-outline-danger rounded-end" asp-action="Delete" asp-route-id="@item.MaLich">
                                        <i class="fas fa-trash me-1"></i> Hủy lịch
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">
                            <i class="fas fa-calendar-times fa-3x mb-3 opacity-50"></i>
                            <p>Chưa có lịch công tác nào được lên kế hoạch.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
var successMessage = '@TempData["SuccessMessage"]';
            var errorMessage = '@Html.Raw(TempData["ErrorMessage"])';

            if (successMessage && successMessage.length > 0) {
                Swal.fire({ icon: 'success', title: 'Thành công!', text: successMessage, timer: 2000, showConfirmButton: false });
            }
            if (errorMessage && errorMessage.length > 0) {
                Swal.fire({ icon: 'error', title: 'Lỗi!', text: errorMessage });
            }

            // Tìm kiếm nhanh
            document.getElementById('mainSearch').addEventListener('keyup', function () {
                let val = this.value.toLowerCase();
                let rows = document.querySelectorAll('#masterTable tbody tr');
                rows.forEach(row => {
                    if(row.innerText.includes("Chưa có lịch")) return;
                    row.style.display = row.innerText.toLowerCase().includes(val) ? '' : 'none';
                });
            });
        });
    </script>
}
