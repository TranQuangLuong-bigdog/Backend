@model KhoaNoiVuCNTT.Models.BoMon

@{
    ViewData["Title"] = "Xác nhận Xóa Bộ Môn";
}

<div class="container-fluid py-4 px-lg-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm border-danger border-2" style="border-radius: 16px;">
                <div class="card-header bg-danger text-white text-center pt-4 pb-3" style="border-radius: 14px 14px 0 0;">
                    <i class="fas fa-exclamation-triangle fa-3x mb-3 opacity-75"></i>
                    <h4 class="mb-0 fw-bold">Xác nhận xóa tổ chuyên môn</h4>
                </div>
                
                <div class="card-body p-4 text-center">
                    <p class="fs-5 mb-4 text-dark">Bạn có chắc chắn muốn xóa bộ môn này khỏi hệ thống không? Hành động này không thể hoàn tác.</p>
                    
                    <div class="bg-light p-4 rounded-3 text-start mb-4 border">
                        <dl class="row mb-0 fs-6">
                            <dt class="col-sm-4 text-muted">Mã Bộ Môn:</dt>
                            <dd class="col-sm-8 fw-bold text-dark">#@Model.MaBoMon</dd>

                            <dt class="col-sm-4 text-muted mt-2">Tên Bộ Môn:</dt>
                            <dd class="col-sm-8 mt-2">
                                <span class="badge bg-secondary fs-6 px-3 py-2">@Model.TenBoMon</span>
                            </dd>
                        </dl>
                    </div>

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger text-start small mb-4">
                            <i class="fas fa-ban me-2"></i> @TempData["ErrorMessage"]
                        </div>
                    }

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="MaBoMon" />
                        
                        <div class="d-flex justify-content-center gap-3 mt-2">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2" style="border-radius: 8px;">
                                <i class="fas fa-arrow-left me-2"></i>Quay lại
                            </a>
                            <button type="submit" class="btn btn-danger px-4 py-2 shadow-sm" style="border-radius: 8px;">
                                <i class="fas fa-trash-alt me-2"></i>Xác nhận Xóa
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
