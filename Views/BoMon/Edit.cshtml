@model KhoaNoiVuCNTT.Models.BoMon

@{
    ViewData["Title"] = "Cập nhật Bộ Môn";
}

<div class="container-fluid py-4 px-lg-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0" style="border-radius: 16px;">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <div class="d-flex align-items-center">
                        <a asp-action="Index" class="btn btn-sm btn-outline-secondary rounded-circle me-3" style="width: 32px; height: 32px; padding: 3px; display: flex; align-items: center; justify-content: center;">
                            <i class="fas fa-arrow-left"></i>
                        </a>
                        <h4 class="mb-0 fw-bold text-warning"><i class="fas fa-edit me-2"></i>Cập nhật Tổ chuyên môn</h4>
                    </div>
                </div>
                
                <div class="card-body p-4">
                    <form asp-action="Edit" class="needs-validation" novalidate>
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>
                        
                        <input type="hidden" asp-for="MaBoMon" />
                        
                        <div class="mb-4">
                            <label asp-for="TenBoMon" class="form-label fw-bold small text-muted">Tên Bộ Môn (Tổ chuyên môn) <span class="text-danger">*</span></label>
                            <input asp-for="TenBoMon" class="form-control form-control-lg fs-6" style="border-radius: 10px;" required minlength="3" />
                            <span asp-validation-for="TenBoMon" class="text-danger small mt-1 d-block"></span>
                            
                            @if (!ViewData.ModelState.IsValid && ViewData.ModelState["TenBoMon"]?.Errors.Count > 0)
                            {
                                <div class="text-danger small mt-1">
                                    <i class="fas fa-exclamation-circle me-1"></i> @ViewData.ModelState["TenBoMon"].Errors[0].ErrorMessage
                                </div>
                            }
                        </div>

                        <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-light px-4 me-2" style="border-radius: 8px;">Hủy bỏ</a>
                            <button type="submit" class="btn btn-warning px-4 shadow-sm text-dark" style="border-radius: 8px;">
                                <i class="fas fa-sync-alt me-2"></i>Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    
    <script>
        // Validation form của Bootstrap (Bắt lỗi nếu bỏ trống tên)
                (function () {
                    'use strict'
                    var forms = document.querySelectorAll('.needs-validation')
                    Array.prototype.slice.call(forms).forEach(function (form) {
                        form.addEventListener('submit', function (event) {
                            if (!form.checkValidity()) {
                                event.preventDefault()
                                event.stopPropagation()
                            }
                            form.classList.add('was-validated')
                        }, false)
                    })
                })()
    </script>
}