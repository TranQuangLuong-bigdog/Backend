@model KhoaNoiVuCNTT.Models.CanBo

@{
    ViewData["Title"] = "Chỉnh sửa Cán Bộ";
}

<div class="container-fluid py-4 px-lg-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0" style="border-radius: 16px;">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <div class="d-flex align-items-center">
                        <a asp-action="Index" class="btn btn-sm btn-outline-secondary rounded-circle me-3" style="width: 32px; height: 32px; padding: 3px;">
                            <i class="fas fa-arrow-left"></i>
                        </a>
                        <h4 class="mb-0 fw-bold text-warning"><i class="fas fa-user-edit me-2"></i>Cập nhật thông tin: @Model.HoTen</h4>
                    </div>
                </div>
                
                <div class="card-body p-4">
                    <form asp-action="Edit" class="needs-validation" novalidate>
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="MaCanBo" />
                        
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label asp-for="HoTen" class="form-label fw-bold small text-muted">Họ và Tên</label>
                                <input asp-for="HoTen" class="form-control" style="border-radius: 10px;" required />
                                <span asp-validation-for="HoTen" class="text-danger small"></span>
                            </div>
                            
                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label fw-bold small text-muted">Email liên hệ</label>
                                <input asp-for="Email" type="email" class="form-control" style="border-radius: 10px;" required />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="MatKhau" class="form-label fw-bold small text-muted">Mật khẩu</label>
                                <input asp-for="MatKhau" type="password" class="form-control" style="border-radius: 10px;" required />
                                <span asp-validation-for="MatKhau" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="MaBoMon" class="form-label fw-bold small text-muted">Trực thuộc Bộ môn</label>
                                <select asp-for="MaBoMon" class="form-select" asp-items="ViewBag.MaBoMon" style="border-radius: 10px;"></select>
                                <span asp-validation-for="MaBoMon" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="MaVaiTro" class="form-label fw-bold small text-muted">Vai trò hệ thống</label>
                                <select asp-for="MaVaiTro" class="form-select" asp-items="ViewBag.MaVaiTro" style="border-radius: 10px;"></select>
                                <span asp-validation-for="MaVaiTro" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end mt-5 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-light px-4 me-2" style="border-radius: 8px;">Hủy bỏ</a>
                            <button type="submit" class="btn btn-warning px-4 shadow-sm text-dark" style="border-radius: 8px;">
                                <i class="fas fa-sync-alt me-2"></i>Cập nhật
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
