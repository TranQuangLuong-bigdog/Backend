@model KhoaNoiVuCNTT.Models.CanBo

@{
    ViewData["Title"] = "Thêm mới Cán Bộ";
}

<div class="container-fluid py-4 px-lg-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0" style="border-radius: 16px;">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <div class="d-flex align-items-center">
                        <a asp-action="Index" class="btn btn-sm btn-outline-secondary rounded-circle me-3" style="width: 32px; height: 32px; padding: 3px;">
                            <i class="fas fa-arrow-left"></i>
                        </a>
                        <h4 class="mb-0 fw-bold text-primary"><i class="fas fa-user-plus me-2"></i>Thêm Cán Bộ Mới</h4>
                    </div>
                </div>
                
                <div class="card-body p-4">
                    <form asp-action="Create" class="needs-validation" novalidate>
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label asp-for="HoTen" class="form-label fw-bold small text-muted">Họ và Tên <span class="text-danger">*</span></label>
                                <input asp-for="HoTen" class="form-control" style="border-radius: 10px;" required />
                                <span asp-validation-for="HoTen" class="text-danger small"></span>
                            </div>
                            
                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label fw-bold small text-muted">Email liên hệ <span class="text-danger">*</span></label>
                                <input asp-for="Email" type="email" class="form-control" style="border-radius: 10px;" required />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="MatKhau" class="form-label fw-bold small text-muted">Mật khẩu khởi tạo <span class="text-danger">*</span></label>
                                <input asp-for="MatKhau" type="password" class="form-control" style="border-radius: 10px;" required />
                                <div class="form-text">Mật khẩu để cán bộ đăng nhập vào hệ thống.</div>
                                <span asp-validation-for="MatKhau" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="MaBoMon" class="form-label fw-bold small text-muted">Trực thuộc Bộ môn</label>
                                <select asp-for="MaBoMon" class="form-select" asp-items="ViewBag.MaBoMon" style="border-radius: 10px;"></select>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="MaVaiTro" class="form-label fw-bold small text-muted">Vai trò hệ thống</label>
                                <select asp-for="MaVaiTro" class="form-select" asp-items="ViewBag.MaVaiTro" style="border-radius: 10px;"></select>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end mt-5 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-light px-4 me-2" style="border-radius: 8px;">Hủy bỏ</a>
                            <button type="submit" class="btn btn-primary px-4 shadow-sm" style="border-radius: 8px;">
                                <i class="fas fa-save me-2"></i>Lưu thông tin
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}