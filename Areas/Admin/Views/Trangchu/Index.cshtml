@{
    Layout = null; // Tắt layout mặc định
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Admin - Nội Vụ Khoa CNTT</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
            /* CSS tuỳ chỉnh mô phỏng giao diện trong ảnh */
            body {
                margin: 0;
                background-color: #ecf0f5;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                display: flex;
                height: 100vh;
                overflow: hidden;
            }

            /* Cột Sidebar bên trái */
            .sidebar {
                width: 230px;
                background-color: #222d32;
                color: #fff;
                display: flex;
                flex-direction: column;
                flex-shrink: 0;
            }

            .sidebar-logo {
                height: 50px;
                background-color: #367fa9;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 20px;
                font-weight: bold;
            }

            .user-panel {
                padding: 15px;
                display: flex;
                align-items: center;
                border-bottom: 1px solid #1a2226;
            }

                .user-panel img {
                    width: 45px;
                    height: 45px;
                    border-radius: 50%;
                    margin-right: 15px;
                }

            .user-info p {
                margin: 0;
                font-weight: bold;
            }

            .user-info span {
                font-size: 12px;
                color: #3c8dbc;
            }

            .sidebar-menu {
                list-style: none;
                padding: 0;
                margin: 0;
                overflow-y: auto;
            }

            .sidebar-menu-header {
                padding: 10px 15px;
                font-size: 12px;
                color: #4b646f;
                background: #1a2226;
                text-transform: uppercase;
            }

            .sidebar-menu li a {
                display: block;
                padding: 12px 15px;
                color: #b8c7ce;
                text-decoration: none;
                border-left: 3px solid transparent;
            }

                .sidebar-menu li a:hover, .sidebar-menu li.active a {
                    color: #fff;
                    background: #1e282c;
                    border-left-color: #3c8dbc;
                }

                .sidebar-menu li a i {
                    width: 20px;
                    margin-right: 10px;
                }

            /* Vùng nội dung bên phải */
            .main-content {
                flex-grow: 1;
                display: flex;
                flex-direction: column;
                overflow: hidden;
            }

            /* Thanh Topbar */
            .topbar {
                height: 50px;
                background-color: #3c8dbc;
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0 15px;
                color: #fff;
            }

                .topbar a {
                    color: #fff;
                    text-decoration: none;
                    margin-left: 15px;
                }

            /* Vùng hiển thị Widget */
            .content-body {
                padding: 20px;
                overflow-y: auto;
                flex-grow: 1;
            }

            .page-header {
                border-bottom: 1px solid #d2d6de;
                padding-bottom: 9px;
                margin-bottom: 20px;
                display: flex;
                align-items: baseline;
            }

                .page-header h3 {
                    margin: 0;
                    font-weight: normal;
                }

                .page-header small {
                    color: #777;
                    margin-left: 10px;
                    font-size: 15px;
                }

            /* Các khối màu (Small Box) */
            .small-box {
                border-radius: 2px;
                position: relative;
                display: block;
                margin-bottom: 20px;
                color: #fff;
                box-shadow: 0 1px 1px rgba(0,0,0,0.1);
            }

                .small-box .inner {
                    padding: 20px;
                }

                .small-box h3 {
                    font-size: 38px;
                    font-weight: bold;
                    margin: 0 0 10px 0;
                    white-space: nowrap;
                    padding: 0;
                }

                .small-box p {
                    font-size: 15px;
                    margin: 0;
                }

                .small-box .icon {
                    transition: all .3s linear;
                    position: absolute;
                    top: -10px;
                    right: 10px;
                    z-index: 0;
                    font-size: 90px;
                    color: rgba(0,0,0,0.15);
                }

                .small-box:hover .icon {
                    font-size: 95px;
                }

            .small-box-footer {
                position: relative;
                text-align: center;
                padding: 3px 0;
                color: rgba(255,255,255,0.8);
                display: block;
                z-index: 10;
                background: rgba(0,0,0,0.1);
                text-decoration: none;
            }

                .small-box-footer:hover {
                    color: #fff;
                    background: rgba(0,0,0,0.15);
                }

            /* Định nghĩa các màu chuẩn */
            .bg-orange {
                background-color: #f39c12 !important;
            }

            .bg-green {
                background-color: #00a65a !important;
            }

            .bg-blue {
                background-color: #00c0ef !important;
            }

            .bg-red {
                background-color: #dd4b39 !important;
            }

            .bg-purple {
                background-color: #8e44ad !important;
            }

            .bg-pink {
                background-color: #e83e8c !important;
            }

            /* Footer */
            .footer {
                background: #fff;
                padding: 15px;
                border-top: 1px solid #d2d6de;
                font-size: 14px;
                display: flex;
                justify-content: space-between;
            }
    </style>
</head>
<body>

    <div class="sidebar">
        <div class="sidebar-logo">Admin</div>

        <div class="user-panel">
            <img src="https://ui-avatars.com/api/?name=Admin&background=0D8ABC&color=fff" alt="User Image">
            <div class="user-info">
                <p>Lê Thị Vân Anh</p>
                <span><i class="fa-solid fa-circle text-success" style="font-size: 10px;"></i> Online</span>
            </div>
        </div>

        <ul class="sidebar-menu">
            <li class="sidebar-menu-header">MENU CHÍNH</li>
            <li class="active"><a href="#"><i class="fa-solid fa-house"></i> Trang chủ</a></li>
            <li><a href="/CanBo"><i class="fa-solid fa-users"></i> Quản lý Cán bộ</a></li>
            <li><a href="/ThongBao"><i class="fa-solid fa-bullhorn"></i> Bảng thông báo</a></li>
            <li><a href="#"><i class="fa-solid fa-calendar-days"></i> Lịch công tác</a></li>
            <li><a href="#"><i class="fa-solid fa-file-pdf"></i> Biểu mẫu & Tài liệu</a></li>
            <li><a href="#"><i class="fa-solid fa-building"></i> Quản lý Bộ môn</a></li>
            <li><a href="#"><i class="fa-solid fa-gear"></i> Cài đặt hệ thống</a></li>
        </ul>
    </div>

    <div class="main-content">
        <div class="topbar">
            <div><i class="fa-solid fa-bars" style="cursor: pointer;"></i></div>
            <div>
                <a href="/Home/Index" class="fa-solid fa-globe">
                    Xem website
                </a>
                <a href="javascript:void(0);">
                    <img src="https://ui-avatars.com/api/?name=Admin&background=0D8ABC&color=fff"
                         style="width: 25px; border-radius: 50%; margin: 0 5px;">
                    Admin
                </a>
            </div>
        </div>

        <div class="content-body">
            <div class="page-header">
                <h3>Tổng quan <small>Bảng điều khiển hệ thống nội vụ</small></h3>
            </div>

            <div class="row">
                <div class="col-lg-4 col-md-6">
                    <div class="small-box bg-orange">
                        <div class="inner">
                            <h3>45</h3>
                            <p>Cán bộ / Giảng viên</p>
                        </div>
                        <div class="icon"><i class="fa-solid fa-user-tie"></i></div>
                        <a href="/CanBo" class="small-box-footer">Chi tiết <i class="fa-solid fa-arrow-circle-right"></i></a>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="small-box bg-green">
                        <div class="inner">
                            <h3>12</h3>
                            <p>Thông báo mới</p>
                        </div>
                        <div class="icon"><i class="fa-solid fa-bell"></i></div>
                        <a href="/ThongBao" class="small-box-footer">Chi tiết <i class="fa-solid fa-arrow-circle-right"></i></a>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="small-box bg-blue">
                        <div class="inner">
                            <h3>128</h3>
                            <p>Tài liệu & Biểu mẫu</p>
                        </div>
                        <div class="icon"><i class="fa-solid fa-folder-open"></i></div>
                        <a href="/Tailieu" class="small-box-footer">Chi tiết <i class="fa-solid fa-arrow-circle-right"></i></a>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="small-box bg-purple">
                        <div class="inner">
                            <h3>3</h3>
                            <p>Tổ Bộ môn</p>
                        </div>
                        <div class="icon"><i class="fa-solid fa-sitemap"></i></div>
                        <a href="/Bomon" class="small-box-footer">Chi tiết <i class="fa-solid fa-arrow-circle-right"></i></a>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="small-box bg-red">
                        <div class="inner">
                            <h3>5</h3>
                            <p>Quản trị viên / Giáo vụ</p>
                        </div>
                        <div class="icon"><i class="fa-solid fa-user-shield"></i></div>
                        <a href="/QuanTriVien" class="small-box-footer">Chi tiết <i class="fa-solid fa-arrow-circle-right"></i></a>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="small-box bg-pink">
                        <div class="inner">
                            <h3>8</h3>
                            <p>Sự kiện tuần này</p>
                        </div>
                        <div class="icon"><i class="fa-solid fa-calendar-check"></i></div>
                        <a href="/LichCongTac" class="small-box-footer">Chi tiết <i class="fa-solid fa-arrow-circle-right"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <div class="footer">
            <div><strong>Copyright © 2026</strong> Khoa Công Nghệ Thông Tin.</div>
            <div>Version 1.0</div>
        </div>
    </div>

</body>
</html>